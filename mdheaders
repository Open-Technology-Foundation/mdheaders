#!/bin/bash
# mdheaders - Manipulate markdown header levels while preserving code blocks
# https://github.com/Open-Technology-Foundation/mdheaders
# License: GPL-3.0

# Require Bash 5+ (inherit_errexit, ${var@Q}, extended-regex intervals)
if ((BASH_VERSINFO[0] < 5)); then
  printf '%s: requires Bash 5.0 or newer\n' "${0##*/}" >&2
  exit 1
fi

set -euo pipefail
shopt -s inherit_errexit shift_verbose extglob nullglob

# Harden PATH to standard locations before invoking any external command
export PATH='/usr/local/bin:/usr/bin:/bin'

# Script Metadata
declare -r VERSION='1.3.0'
#shellcheck disable=SC2155
declare -r SCRIPT_PATH=$(realpath -- "$0")
declare -r SCRIPT_NAME=${SCRIPT_PATH##*/}

declare -i VERBOSE=1
declare -- TMPFILE=''   # hoisted so the EXIT trap can see it after main() returns

# Standard colors - only if terminal output
if [[ -t 1 && -t 2 ]]; then
  declare -r RED=$'\033[0;31m' YELLOW=$'\033[0;33m' CYAN=$'\033[0;36m' NC=$'\033[0m'
else
  declare -r RED='' YELLOW='' CYAN='' NC=''
fi

# Core message function using FUNCNAME for context
_msg() {
  local -- prefix="$SCRIPT_NAME:" msg
  case ${FUNCNAME[1]} in
    warn)    prefix+=" ${YELLOW}▲${NC}" ;;
    info)    prefix+=" ${CYAN}◉${NC}" ;;
    error)   prefix+=" ${RED}✗${NC}" ;;
    *)       ;;
  esac
  for msg in "$@"; do printf '%s %s\n' "$prefix" "$msg"; done
}

# Conditional output based on verbosity
warn() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
info() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }

# Unconditional output (errors are never silenced by --quiet)
error() { >&2 _msg "$@"; }
die() { (($# > 1)) && error "${@:2}" ||:; exit "${1:-0}"; }

# Remove the temp file on exit or signal (recursion-guarded by resetting traps)
_cleanup() { trap - EXIT INT TERM; rm -f -- "${TMPFILE:-}"; }

# Validate option has an argument that is not itself an option
noarg() {
  { (($# > 1)) && [[ $2 != -?* || $2 == -+([0-9]) ]]; } \
    || die 2 "Option ${1@Q} requires an argument"
}

# Validate a string is a non-negative integer (guards arithmetic-context assignment)
is_uint() { [[ $1 =~ ^[0-9]+$ ]]; }

# English pluralizer - outputs 's' unless count is 1
# Usage: "file$(s "${#files[@]}")" -> "file" or "files"
s() { (( ${1:-1} == 1 )) || echo -n 's'; }

# Process markdown content and modify header levels
# Args:
#   $1: delta (positive=upgrade, negative=downgrade)
#   $2: error mode ("skip" or "stop")
# Input: markdown content via stdin
# Output: modified markdown to stdout
# Returns: 0 on success (incl. no-op pass-through), 1 on stop-on-error abort
mdh_process() {
  local -i delta=$1
  local -- error_mode="${2:-skip}"

  local -i in_code_block=0 fence_len=0
  local -- fence_char='' line out='' close_regex='' indent hashes rest new_hashes
  local -i modified=0 skipped=0 line_num=0 current_level new_level had_nl=1
  local -- fence_open_regex='^[[:space:]]{0,3}(`{3,}|~{3,})'

  # `|| { had_nl=0; [[ -n $line ]]; }` flushes a final line that lacks a newline
  while IFS= read -r line || { had_nl=0; [[ -n $line ]]; }; do
    line_num+=1

    if ((in_code_block)); then
      # Inside a fence: only a matching-or-longer run of the same char closes it
      if [[ $line =~ $close_regex ]]; then in_code_block=0; fi
      out=$line
    elif [[ $line =~ $fence_open_regex ]]; then
      # Opening fence: remember its char and run length for the close test
      in_code_block=1
      fence_char=${BASH_REMATCH[1]:0:1}
      fence_len=${#BASH_REMATCH[1]}
      close_regex="^[[:space:]]{0,3}[${fence_char}]{${fence_len},}[[:space:]]*$"
      out=$line
    elif [[ $line =~ ^([[:space:]]{0,3})(#{1,6})([[:space:]].*)?$ ]]; then
      # Valid ATX header: 0-3 indent, 1-6 hashes, then space-or-EOL (7+ hashes = text)
      indent=${BASH_REMATCH[1]}
      hashes=${BASH_REMATCH[2]}
      rest=${BASH_REMATCH[3]}
      current_level=${#hashes}
      new_level=$((current_level + delta))

      if ((new_level < 1)); then
        skipped+=1
        if [[ $error_mode == stop ]]; then
          error "Line $line_num: aborting - cannot downgrade H$current_level (already at minimum)"
          return 1
        fi
        warn "Line $line_num: Cannot downgrade H$current_level (already at minimum)"
        out=$line
      elif ((new_level > 6)); then
        skipped+=1
        if [[ $error_mode == stop ]]; then
          error "Line $line_num: aborting - cannot upgrade H$current_level (already at maximum)"
          return 1
        fi
        warn "Line $line_num: Cannot upgrade H$current_level (already at maximum)"
        out=$line
      else
        printf -v new_hashes '%*s' "$new_level" ''
        new_hashes=${new_hashes// /#}
        out="${indent}${new_hashes}${rest}"
        modified+=1
      fi
    else
      out=$line
    fi

    if ((had_nl)); then printf '%s\n' "$out"; else printf '%s' "$out"; fi
  done

  if ((in_code_block)); then warn 'File ended with unclosed code block'; fi
  if ((modified > 0 || skipped > 0)); then
    info "Processed $modified header$(s "$modified"), skipped $skipped"
  fi

  # No-op pass-through (skip mode, nothing shiftable) is success, not an error.
  return 0
}

# mdh_upgrade - Increase header levels (# -> ##, ## -> ###, etc.)
# Args: $1 levels (default 1); $2 error_mode (skip|stop)
# Input: markdown via stdin; Output: transformed markdown to stdout
mdh_upgrade() {
  local -i levels="${1:-1}"
  local -- error_mode="${2:-skip}"
  ((levels >= 1)) || { error 'Upgrade levels must be >= 1'; return 1; }
  mdh_process "$levels" "$error_mode"
}

# mdh_downgrade - Decrease header levels (## -> #, ### -> ##, etc.)
# Args: $1 levels (default 1); $2 error_mode (skip|stop)
# Input: markdown via stdin; Output: transformed markdown to stdout
mdh_downgrade() {
  local -i levels="${1:-1}"
  local -- error_mode="${2:-skip}"
  ((levels >= 1)) || { error 'Downgrade levels must be >= 1'; return 1; }
  mdh_process "-$levels" "$error_mode"
}

# mdh_detect_min_level - Find the smallest header level in a document
# Scans while respecting code-block boundaries.
# Input: markdown via stdin; Output: minimum header level (1-6) to stdout
# Returns: 0 if headers found, 1 if none
mdh_detect_min_level() {
  local -i in_code_block=0 min_level=7 level fence_len=0
  local -- fence_char='' line close_regex='' hashes
  local -- fence_open_regex='^[[:space:]]{0,3}(`{3,}|~{3,})'

  while IFS= read -r line || [[ -n $line ]]; do
    if ((in_code_block)); then
      if [[ $line =~ $close_regex ]]; then in_code_block=0; fi
      continue
    elif [[ $line =~ $fence_open_regex ]]; then
      in_code_block=1
      fence_char=${BASH_REMATCH[1]:0:1}
      fence_len=${#BASH_REMATCH[1]}
      close_regex="^[[:space:]]{0,3}[${fence_char}]{${fence_len},}[[:space:]]*$"
      continue
    fi

    if [[ $line =~ ^[[:space:]]{0,3}(#{1,6})([[:space:]].*)?$ ]]; then
      hashes="${BASH_REMATCH[1]}"
      level=${#hashes}
      if ((level < min_level)); then min_level=$level; fi
    fi
  done

  if ((min_level == 7)); then return 1; fi
  printf '%d' "$min_level"
  return 0
}

# mdh_normalize - Adjust all headers so the minimum level matches target
# Two passes: detect current minimum, then shift all headers.
# Args: $1 target_level 1-6 (default 1); $2 error_mode (skip|stop)
# Input: markdown via stdin; Output: normalized markdown to stdout
# Returns: 0 on success, 1 if no headers found or aborted
mdh_normalize() {
  local -i target_level="${1:-1}"
  local -- error_mode="${2:-skip}"

  if ((target_level < 1 || target_level > 6)); then
    error 'Target level must be between 1 and 6'
    return 1
  fi

  # Store stdin to a temp file so we can read it twice. Install the cleanup
  # trap before creating the file (RETURN fires in-scope, on every exit path).
  local -- temp_content=''
  trap 'rm -f -- "${temp_content:-}"' RETURN
  temp_content=$(mktemp) || { error 'Failed to create temporary file'; return 1; }

  cat > "$temp_content"

  local -i min_level delta
  if ! min_level=$(mdh_detect_min_level < "$temp_content"); then
    error 'No headers found in document'
    return 1
  fi

  delta=$((target_level - min_level))
  info "Detected minimum level: H$min_level, target: H$target_level, delta: $delta"

  if ((delta == 0)); then
    info "Document already normalized to H$target_level"
    cat -- "$temp_content"
    return 0
  fi

  mdh_process "$delta" "$error_mode" < "$temp_content"
  local -i result=$?
  return "$result"
}

# show_usage - Display help text
show_usage() {
  cat <<'EOF'
Usage: mdheaders {upgrade|downgrade|normalize|up|down|norm} [OPTIONS] FILE

Manipulate markdown header levels while preserving code blocks.

Commands:
  upgrade, up         Increase header levels (# -> ##)
  downgrade, down     Decrease header levels (## -> #)
  normalize, norm     Auto-adjust all headers to start at target level

Options:
  -l, --levels=N         Number of levels to shift (default: 1)
  -s, --start-level=N    Target starting level for normalize (default: 1)
  -o, --output=FILE      Output file (default: stdout)
  -i, --in-place         Modify file in-place
  -b, --backup[=SUFFIX]  Create backup before in-place edit (long form takes
                         the suffix; short -b uses .bak; default suffix .bak)
  --skip-errors          Skip invalid headers with warning (default)
  --stop-on-error        Abort on first invalid header
  -q, --quiet            Suppress warnings and progress messages
  -v, --verbose          Show detailed processing information (default)
  -V, --version          Show version
  -h, --help             Show this help message
  --                     End of options (following FILE may start with '-')

Examples:
  mdheaders up README.md              # Upgrade headers by 1 level
  mdheaders down -ib doc.md           # Downgrade in-place with backup
  mdheaders up -l 2 -o NEW.md OLD.md  # Upgrade by 2, save to new file
  mdheaders norm -s 2 README.md       # Normalize to start at H2

Behavior:
  - Fenced code blocks (``` and ~~~) are preserved; headers inside are not
    modified. A closing fence must be at least as long as the opening run.
  - Only ATX headers (#..######) are recognized; up to 3 leading spaces are
    allowed. Setext (=== / ---) underlines are left unchanged.
  - Lines with 7 or more leading # are text, not headers, and are not modified.
  - Headers cannot go below H1 (#) or above H6 (######).
  - In-place edits rewrite the existing file (inode, mode, owner, symlinks and
    hardlinks are preserved).
  - The normalize command uses two passes: detect minimum, then shift all.

Exit codes:
  0  Success (including a no-op when nothing needs shifting)
  1  Processing error (file not found, no headers, write failure, abort)
  2  Invalid arguments

More info: https://github.com/Open-Technology-Foundation/mdheaders
EOF
}

# Main function
main() {
  # Default values
  local -- command=''
  local -i levels=1 start_level=1 in_place=0
  local -- output_file='' backup_suffix='' error_mode='skip' input_file='' optval='' _opt=''
  local -a _split=()

  # Parse command
  if (($# == 0)); then
    show_usage >&2
    return 2
  fi

  case $1 in
    upgrade|up)        command='upgrade'; shift ;;
    downgrade|down)    command='downgrade'; shift ;;
    normalize|norm)    command='normalize'; shift ;;
    -V|--version)      echo "$SCRIPT_NAME $VERSION"; return 0 ;;
    -h|--help|help)    show_usage; return 0 ;;
    *)                 die 2 "Unknown command ${1@Q}" 'Use --help for usage information' ;;
  esac

  # Parse options
  while (($#)); do case $1 in
    -l|--levels)
      noarg "$@"; shift
      is_uint "$1" || die 2 "Option '--levels' requires a non-negative integer, got ${1@Q}"
      levels=$1
      ;;
    --levels=*)
      optval=${1#*=}
      is_uint "$optval" || die 2 "Option '--levels' requires a non-negative integer, got ${optval@Q}"
      levels=$optval
      ;;
    -s|--start-level)
      noarg "$@"; shift
      is_uint "$1" || die 2 "Option '--start-level' requires a non-negative integer, got ${1@Q}"
      start_level=$1
      ;;
    --start-level=*)
      optval=${1#*=}
      is_uint "$optval" || die 2 "Option '--start-level' requires a non-negative integer, got ${optval@Q}"
      start_level=$optval
      ;;
    -o|--output)
      noarg "$@"; shift; output_file=$1
      ;;
    --output=*)
      output_file=${1#*=}
      ;;
    -i|--in-place)     in_place=1 ;;
    -b|--backup)       backup_suffix='.bak' ;;
    --backup=*)        backup_suffix=${1#*=} ;;
    --skip-errors)     error_mode='skip' ;;
    --stop-on-error)   error_mode='stop' ;;
    -q|--quiet)        VERBOSE=0 ;;
    -v|--verbose)      VERBOSE=1 ;;
    -V|--version)      echo "$SCRIPT_NAME $VERSION"; return 0 ;;
    -h|--help)         show_usage; return 0 ;;
    -[ibqvVh]?*)
      # Disaggregate bundled short flags (-iq -> -i -q). Value options (-l/-s/-o)
      # are not in the class; if bundled they split out and fall through to a
      # clean usage error rather than crashing.
      _opt=${1:1}; _split=()
      while [[ -n $_opt ]]; do _split+=("-${_opt:0:1}"); _opt=${_opt:1}; done
      set -- '' "${_split[@]}" "${@:2}"
      ;;
    --)
      shift
      while (($#)); do
        if [[ -z $input_file ]]; then input_file=$1
        else die 2 "Multiple input files specified ${1@Q}"; fi
        shift
      done
      break
      ;;
    -*)                die 2 "Unknown option ${1@Q}" ;;
    '')                ;;
    *)
      if [[ -z $input_file ]]; then input_file=$1
      else die 2 "Multiple input files specified ${1@Q}"; fi
      ;;
  esac; shift; done
  readonly VERBOSE

  # Validate arguments
  [[ -n $input_file ]] || die 2 'No input file specified'
  [[ -f $input_file ]] || die 1 "File not found ${input_file@Q}"
  if ((in_place)) && [[ -n $output_file ]]; then
    die 2 'Cannot use both --in-place and --output'
  fi
  if [[ -n $output_file && -d $output_file ]]; then
    die 2 "Output path is a directory ${output_file@Q}"
  fi

  case $command in
    upgrade|downgrade)
      ((levels >= 1)) || die 2 'Levels must be >= 1' ;;
    normalize)
      ((start_level >= 1 && start_level <= 6)) \
        || die 2 "Start level must be between 1 and 6, got $start_level" ;;
  esac

  if ((${#backup_suffix} > 0)) && ((in_place == 0)); then
    warn 'Ignoring --backup: only applies with --in-place'
  fi

  # Install cleanup traps before creating the temp file so a signal in the
  # window cannot leak it. TMPFILE is global so the handler sees it.
  trap _cleanup EXIT
  trap '_cleanup; exit 130' INT
  trap '_cleanup; exit 143' TERM
  TMPFILE=$(mktemp) || die 1 'Failed to create temporary file'

  local -i result=0
  case $command in
    upgrade)   mdh_upgrade   "$levels"      "$error_mode" < "$input_file" > "$TMPFILE" || result=$? ;;
    downgrade) mdh_downgrade "$levels"      "$error_mode" < "$input_file" > "$TMPFILE" || result=$? ;;
    normalize) mdh_normalize "$start_level" "$error_mode" < "$input_file" > "$TMPFILE" || result=$? ;;
  esac

  # Emit output only on success (a stop-on-error abort discards partial output).
  if ((result == 0)); then
    if ((in_place)); then
      if ((${#backup_suffix} > 0)); then
        local -- backup_file="${input_file}${backup_suffix}"
        if [[ -e $backup_file ]]; then
          die 1 "Backup already exists ${backup_file@Q} (refusing to overwrite)"
        fi
        cp -p -- "$input_file" "$backup_file" || die 1 'Failed to create backup file'
        info "Created backup ${backup_file@Q}"
      fi
      # Rewrite in place to preserve inode, mode, owner, symlinks and hardlinks.
      cat -- "$TMPFILE" > "$input_file" || die 1 "Failed to write output file ${input_file@Q}"
      info "Modified ${input_file@Q} in-place"
    elif [[ -n $output_file ]]; then
      cat -- "$TMPFILE" > "$output_file" || die 1 "Failed to write output file ${output_file@Q}"
      info "Wrote output to ${output_file@Q}"
    else
      cat -- "$TMPFILE"
    fi
  fi

  return "$result"
}

main "$@"
#fin
